{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "node": "22"
  },
  "steps": {
    "install-claude-cli": {
      "commands": [
        "npm install -g @anthropic-ai/claude-code",
        "mkdir -p /usr/local/bin && ln -sf $(ls /mise/installs/node/*/bin/claude | head -1) /usr/local/bin/claude"
      ]
    }
  }
}
