{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "node": "22"
  },
  "steps": {
    "install-claude-cli": {
      "commands": [
        "npm install -g @anthropic-ai/claude-code",
        "find /mise -name claude -type f 2>/dev/null || true",
        "ls -la /mise/shims/ 2>/dev/null || true",
        "ls -la /mise/installs/node/*/bin/ 2>/dev/null || true"
      ]
    }
  }
}
