{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "node": "22"
  },
  "steps": {
    "install-claude-cli": {
      "commands": [
        "npm install -g @anthropic-ai/claude-code",
        "npm root -g",
        "ls -la $(npm root -g)/../bin/",
        "ln -sf $(npm root -g)/../bin/claude /usr/local/bin/claude",
        "ls -la /usr/local/bin/claude"
      ]
    }
  }
}
